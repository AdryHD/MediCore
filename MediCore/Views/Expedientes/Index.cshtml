@{
    ViewBag.Title = "Expedientes";
}

<div class="page-heading">

    <div>

        <span class="section-eyebrow">
            EXPEDIENTES CLÍNICOS
        </span>

        <h3>Expedientes</h3>

        <p class="text-subtitle text-muted">
            Administración de expedientes médicos.
        </p>

    </div>

</div>

<section class="section">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow-sm">

                <div class="card-body text-center py-5">

                    <i class="bi bi-folder2-open"
                       style="font-size:90px;color:#435ebe;"></i>

                    <h2 class="mt-4">

                        Módulo en construcción

                    </h2>

                    <p class="text-muted mt-3">

                        El módulo de Expedientes Clínicos aún se encuentra en desarrollo.
                        Próximamente estará disponible con todas sus funcionalidades.

                    </p>

                    <div class="mt-4">

                        <a href="@Url.Action("Principal","Home")"
                           class="btn btn-primary btn-lg">

                            <i class="bi bi-house-door-fill me-2"></i>

                            Regresar al Menú Principal

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>