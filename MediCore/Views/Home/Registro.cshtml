@model MediCore.Models.UsuarioModel
@{
    ViewBag.Title = "Registro de Paciente";
    Layout = "~/Views/Shared/_LayoutExterno.cshtml";
}

<div id="auth-card">

    <div class="auth-logo">
        <a href="@Url.Action("Index", "Home")" class="auth-logo-wrapper">
            <img src="~/Content/images/LogoMediCore.png" alt="MediCore" class="auth-logo-img" width="154">
        </a>
    </div>

    <h1 class="auth-title">Crear cuenta</h1>
    <p class="auth-subtitle">Completa los datos para registrarte como paciente en MediCore.</p>

    <div class="auth-divider"><span>Datos del paciente</span></div>

    @using (Html.BeginForm("Registro", "Home", FormMethod.Post, new { id = "RegistroForm" }))
    {
        @Html.AntiForgeryToken()

        <div class="form-group position-relative has-icon-left mb-4">
            @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control", @placeholder = "Nombre completo" })
            <div class="form-control-icon"><i class="bi bi-person"></i></div>
        </div>

        <div class="form-group position-relative has-icon-left mb-4">
            @Html.TextBoxFor(m => m.Cedula, new { @class = "form-control", @placeholder = "Cédula o documento de identidad" })
            <div class="form-control-icon"><i class="bi bi-card-text"></i></div>
        </div>

        <div class="form-group position-relative has-icon-left mb-4">
            @Html.TextBoxFor(m => m.FechaNacimiento, new { @class = "form-control", @type = "date" })
            <div class="form-control-icon"><i class="bi bi-calendar-date"></i></div>
        </div>

        <div class="form-group position-relative has-icon-left mb-4">
            @Html.TextBoxFor(m => m.Telefono, new { @class = "form-control", @placeholder = "Teléfono" })
            <div class="form-control-icon"><i class="bi bi-telephone"></i></div>
        </div>

        <div class="form-group position-relative has-icon-left mb-4">
            @Html.TextBoxFor(m => m.Correo, new { @class = "form-control", @placeholder = "Correo electrónico" })
            <div class="form-control-icon"><i class="bi bi-envelope"></i></div>
        </div>

        <div class="form-group position-relative has-icon-left mb-4">
            @Html.PasswordFor(m => m.Contrasenna, new { @class = "form-control", @placeholder = "Contraseña" })
            <div class="form-control-icon"><i class="bi bi-shield-lock"></i></div>
        </div>

        <div class="form-group position-relative has-icon-left mb-4">
            @Html.PasswordFor(m => m.ConfirmarContrasenna, new { @class = "form-control", @placeholder = "Confirmar contraseña" })
            <div class="form-control-icon"><i class="bi bi-shield-check"></i></div>
        </div>

        <button type="submit" class="btn btn-primary btn-block btn-lg w-100 mt-2">
            <i class="bi bi-person-plus-fill me-2"></i>Crear Cuenta
        </button>
    }

    <p class="text-center mt-4 mb-0" style="font-size:0.9rem;color:#7a8aaa;">
        ¿Ya tienes cuenta? <a href="@Url.Action("Index", "Home")" class="fw-bold" style="color:#2d499d;">Iniciar Sesión</a>
    </p>
</div>

@section scripts {
    <script src="~/Scripts/registro.js"></script>
}
