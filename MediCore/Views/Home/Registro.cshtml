@{
    ViewBag.Title = "Registro de Paciente";
    Layout = "~/Views/Shared/_LayoutExterno.cshtml";
}

<div class="row h-100">
    <div class="col-lg-5 col-12">
        <div id="auth-left">
            <div class="auth-logo">
                <a href="@Url.Action("Index", "Home")">
                    <img src="~/Content/images/logo.png" alt="MediCore">
                </a>
            </div>
            <h1 class="auth-title">Registro</h1>
            <p class="auth-subtitle mb-5">Crea tu cuenta como paciente en MediCore.</p>

            <form action="@Url.Action("Registro", "Home")" method="post">
                @Html.AntiForgeryToken()
                <div class="form-group position-relative has-icon-left mb-4">
                    <input type="text" name="nombreCompleto" class="form-control form-control-xl" placeholder="Nombre completo" required>
                    <div class="form-control-icon">
                        <i class="bi bi-person"></i>
                    </div>
                </div>
                <div class="form-group position-relative has-icon-left mb-4">
                    <input type="text" name="cedula" class="form-control form-control-xl" placeholder="Cédula o documento de identidad" required>
                    <div class="form-control-icon">
                        <i class="bi bi-card-text"></i>
                    </div>
                </div>
                <div class="form-group position-relative has-icon-left mb-4">
                    <input type="date" name="fechaNacimiento" class="form-control form-control-xl" placeholder="Fecha de nacimiento" required>
                    <div class="form-control-icon">
                        <i class="bi bi-calendar-date"></i>
                    </div>
                </div>
                <div class="form-group position-relative has-icon-left mb-4">
                    <input type="tel" name="telefono" class="form-control form-control-xl" placeholder="Teléfono">
                    <div class="form-control-icon">
                        <i class="bi bi-telephone"></i>
                    </div>
                </div>
                <div class="form-group position-relative has-icon-left mb-4">
                    <input type="email" name="correo" class="form-control form-control-xl" placeholder="Correo electrónico" required>
                    <div class="form-control-icon">
                        <i class="bi bi-envelope"></i>
                    </div>
                </div>
                <div class="form-group position-relative has-icon-left mb-4">
                    <input type="password" name="contrasena" class="form-control form-control-xl" placeholder="Contraseña" required>
                    <div class="form-control-icon">
                        <i class="bi bi-shield-lock"></i>
                    </div>
                </div>
                <div class="form-group position-relative has-icon-left mb-4">
                    <input type="password" name="confirmarContrasena" class="form-control form-control-xl" placeholder="Confirmar contraseña" required>
                    <div class="form-control-icon">
                        <i class="bi bi-shield-check"></i>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary btn-block btn-lg shadow-lg mt-5">Crear Cuenta</button>
            </form>

            <div class="text-center mt-5 text-lg fs-4">
                <p class="text-gray-600">
                    ¿Ya tienes cuenta? <a href="@Url.Action("Index", "Home")" class="font-bold">Iniciar Sesión</a>.
                </p>
            </div>
        </div>
    </div>
    <div class="col-lg-7 d-none d-lg-block">
        <div id="auth-right"></div>
    </div>
</div>
