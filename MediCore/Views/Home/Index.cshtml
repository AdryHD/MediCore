@{
    ViewBag.Title = "Iniciar Sesión";
    Layout = "~/Views/Shared/_LayoutExterno.cshtml";
}

<div id="auth-card">

    <div class="auth-logo">
        <a href="@Url.Action("Index", "Home")" class="auth-logo-wrapper">
            <img src="~/Content/images/LogoMediCore.png" alt="MediCore" class="auth-logo-img" width="154">
        </a>
    </div>

    <h1 class="auth-title">Bienvenido de nuevo</h1>
    <p class="auth-subtitle">Ingresa tus credenciales para acceder al sistema de gestión médica.</p>

    <div class="auth-divider"><span>Acceso al sistema</span></div>

    <form action="@Url.Action("Index", "Home")" method="post">
        @Html.AntiForgeryToken()

        <div class="form-group position-relative has-icon-left mb-4">
            <input type="email" name="correo" class="form-control" placeholder="Correo electrónico" required>
            <div class="form-control-icon">
                <i class="bi bi-envelope"></i>
            </div>
        </div>

        <div class="form-group position-relative has-icon-left mb-4">
            <input type="password" name="contrasena" class="form-control" placeholder="Contraseña" required>
            <div class="form-control-icon">
                <i class="bi bi-shield-lock"></i>
            </div>
        </div>

        <div class="d-flex align-items-center justify-content-between mb-3">
            <div class="form-check d-flex align-items-center gap-2 m-0">
                <input class="form-check-input m-0" type="checkbox" name="recordarme" id="recordarme">
                <label class="form-check-label" for="recordarme">Recordarme</label>
            </div>
            <a href="@Url.Action("RecuperarAcceso", "Home")" class="auth-link-small">¿Olvidaste tu contraseña?</a>
        </div>

        <button type="submit" class="btn-auth-primary">
            <i class="bi bi-box-arrow-in-right me-2"></i> Iniciar Sesión
        </button>
    </form>

    <div class="auth-footer-links">
        <p>¿No tienes cuenta? <a href="@Url.Action("Registro", "Home")">Regístrate aquí</a></p>
    </div>

</div>
