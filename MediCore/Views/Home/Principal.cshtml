@{
    ViewBag.Title = "Inicio";
    ViewBag.ActiveMenu = "Dashboard";
}

@* Banner de bienvenida *@
<div class="welcome-banner">
    <div class="welcome-banner-left">
        <span class="welcome-eyebrow"><i class="bi bi-grid-fill me-1"></i>PANEL DE CONTROL</span>
        <h2 class="welcome-title">Bienvenido a MediCore</h2>
        <p class="welcome-sub">Hoy es <strong id="welcome-date"></strong> &mdash; Gestiona citas, pacientes y más desde aquí.</p>
    </div>
    <div class="welcome-banner-right">
        <i class="bi bi-heart-pulse welcome-banner-icon"></i>
    </div>
</div>
<script>
    (function () {
        var d = new Date();
        var dias = ['domingo','lunes','martes','miércoles','jueves','viernes','sábado'];
        var meses = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
        document.getElementById('welcome-date').textContent =
            dias[d.getDay()] + ', ' + d.getDate() + ' de ' + meses[d.getMonth()] + ' de ' + d.getFullYear();
    })();
</script>

<div class="page-heading">
    <div>
        <span class="section-eyebrow">RESUMEN GENERAL</span>
        <h3>Indicadores del Sistema</h3>
    </div>
</div>

<section class="section">
    <div class="row g-3 mb-4">

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="stats-card stats-card--blue">
                <div class="stats-icon blue">
                    <i class="bi bi-people-fill"></i>
                </div>
                <div class="stats-info">
                    <h6 class="label">Total Pacientes</h6>
                    <h4 class="value">—</h4>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="stats-card stats-card--teal">
                <div class="stats-icon teal">
                    <i class="bi bi-person-badge-fill"></i>
                </div>
                <div class="stats-info">
                    <h6 class="label">Total Doctores</h6>
                    <h4 class="value">—</h4>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="stats-card stats-card--green">
                <div class="stats-icon green">
                    <i class="bi bi-calendar2-check-fill"></i>
                </div>
                <div class="stats-info">
                    <h6 class="label">Citas Hoy</h6>
                    <h4 class="value">—</h4>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="stats-card stats-card--orange">
                <div class="stats-icon orange">
                    <i class="bi bi-clock-history"></i>
                </div>
                <div class="stats-info">
                    <h6 class="label">Citas Pendientes</h6>
                    <h4 class="value">—</h4>
                </div>
            </div>
        </div>

    </div>

    <div class="row">
        <div class="col-12">
            <div class="section-heading">
                <span class="section-eyebrow">AGENDA</span>
                <h3 class="section-title">Próximas Citas</h3>
            </div>
            <div class="card">
                <div class="card-header">
                    <h4><i class="bi bi-calendar2-week me-2" style="color:#01C0BA;"></i>Próximas Citas</h4>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Paciente</th>
                                    <th>Doctor</th>
                                    <th>Especialidad</th>
                                    <th>Fecha y Hora</th>
                                    <th>Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td colspan="6" class="empty-state-cell">
                                        <div class="empty-state">
                                            <div class="empty-state-icon-wrap">
                                                <i class="bi bi-calendar3"></i>
                                            </div>
                                            <p class="empty-state-title">Sin citas registradas</p>
                                            <p class="empty-state-sub">Aún no hay citas programadas en el sistema.</p>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
