                    <a href="index.html"><img src="~/Content/images/logo.png" alt="Logo"></a>
                </div>
                <h1 class="auth-title">Olvidaste tu contraseña</h1>
                <p class="auth-subtitle mb-5">Ingresa tu contraseña y te enviaremos un link para recuperarla.</p>

                <form action="index.html">
