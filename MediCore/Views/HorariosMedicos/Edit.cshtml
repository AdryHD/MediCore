@model MediCore.Models.HorarioMedicoFormModel
@{
    ViewBag.Title = "Editar Horario Médico";
    ViewBag.ActiveMenu = "Horarios";
    var diasSemana = ViewBag.DiasSemana as System.Collections.Generic.Dictionary<byte, string>;
}

<div class="page-heading">
    <div>
        <span class="section-eyebrow">GESTIÓN MÉDICA</span>
        <h3>Editar Horario Médico</h3>
    </div>
    <div>
        <a href="@Url.Action("Index", "HorariosMedicos")" class="btn btn-light-secondary">
            <i class="bi bi-arrow-left me-1"></i>Volver
        </a>
    </div>
</div>

<section class="section">
    <div class="row">
        <div class="col-12 col-lg-7">
            <div class="card">
                <div class="card-header">
                    <h4><i class="bi bi-clock me-2" style="color:#01C0BA;"></i>Datos del Horario</h4>
                </div>
                <div class="card-body">
                    @using (Html.BeginForm("Edit", "HorariosMedicos", FormMethod.Post, new { id = "HorarioMedicoForm" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(m => m.IdHorario)
                        @Html.ValidationSummary(true, "", new { @class = "alert alert-light-danger" })

                        <div class="form-group mb-3">
                            @Html.LabelFor(m => m.IdDoctor)
                            @Html.DropDownListFor(m => m.IdDoctor, (SelectList)ViewBag.Doctores, "Seleccione un doctor", new { @class = "form-select" })
                            @Html.ValidationMessageFor(m => m.IdDoctor, "", new { @class = "text-danger small" })
                        </div>

                        <div class="form-group mb-3">
                            @Html.LabelFor(m => m.DiaSemana)
                            <select id="DiaSemana" name="DiaSemana" class="form-select">
                                <option value="">Seleccione un día</option>
                                @if (diasSemana != null)
                                {
                                    foreach (var dia in diasSemana)
                                    {
                                        <option value="@dia.Key"@(Model.DiaSemana == dia.Key ? " selected" : "")>@dia.Value</option>
                                    }
                                }
                            </select>
                            @Html.ValidationMessageFor(m => m.DiaSemana, "", new { @class = "text-danger small" })
                        </div>

                        <div class="row">
                            <div class="col-12 col-md-6">
                                <div class="form-group mb-3">
                                    @Html.LabelFor(m => m.HoraInicio)
                                    @Html.TextBoxFor(m => m.HoraInicio, "{0:hh\\:mm}", new { @class = "form-control", type = "time" })
                                    @Html.ValidationMessageFor(m => m.HoraInicio, "", new { @class = "text-danger small" })
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="form-group mb-3">
                                    @Html.LabelFor(m => m.HoraFin)
                                    @Html.TextBoxFor(m => m.HoraFin, "{0:hh\\:mm}", new { @class = "form-control", type = "time" })
                                    @Html.ValidationMessageFor(m => m.HoraFin, "", new { @class = "text-danger small" })
                                </div>
                            </div>
                        </div>

                        <div class="form-group mb-3">
                            @Html.LabelFor(m => m.DuracionCita)
                            @Html.TextBoxFor(m => m.DuracionCita, new { @class = "form-control", type = "number", min = 15, max = 480 })
                            @Html.ValidationMessageFor(m => m.DuracionCita, "", new { @class = "text-danger small" })
                        </div>

                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>Guardar Cambios
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

@section scripts {
    <script src="~/Scripts/horariosmedicos.js?v=@System.IO.File.GetLastWriteTime(Server.MapPath("~/Scripts/horariosmedicos.js")).Ticks"></script>
}
