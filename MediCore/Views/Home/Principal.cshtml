@{
    ViewBag.Title = "Dashboard";
    ViewBag.ActiveMenu = "Dashboard";
}

<div class="page-heading">
    <div>
        <h3>Dashboard</h3>
        <p>Bienvenido a MediCore &mdash; Sistema de Gestión Médica</p>
    </div>
</div>

<section class="section">
    <div class="row g-3 mb-4">

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="stats-card">
                <div class="stats-icon blue">
                    <i class="bi bi-people-fill"></i>
                </div>
                <div class="stats-info">
                    <h6 class="label">Total Pacientes</h6>
                    <h4 class="value">—</h4>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="stats-card">
                <div class="stats-icon teal">
                    <i class="bi bi-person-badge-fill"></i>
                </div>
                <div class="stats-info">
                    <h6 class="label">Total Doctores</h6>
                    <h4 class="value">—</h4>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="stats-card">
                <div class="stats-icon green">
                    <i class="bi bi-calendar2-check-fill"></i>
                </div>
                <div class="stats-info">
                    <h6 class="label">Citas Hoy</h6>
                    <h4 class="value">—</h4>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="stats-card">
                <div class="stats-icon orange">
                    <i class="bi bi-clock-history"></i>
                </div>
                <div class="stats-info">
                    <h6 class="label">Citas Pendientes</h6>
                    <h4 class="value">—</h4>
                </div>
            </div>
        </div>

    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h4><i class="bi bi-calendar2-week me-2" style="color:#01C0BA;"></i>Próximas Citas</h4>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Paciente</th>
                                    <th>Doctor</th>
                                    <th>Especialidad</th>
                                    <th>Fecha y Hora</th>
                                    <th>Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td colspan="6" class="text-center py-5" style="color:#6b84a0;">
                                        <i class="bi bi-calendar-x" style="font-size:2rem;display:block;margin-bottom:0.5rem;opacity:0.4;"></i>
                                        No hay citas registradas aún.
                                    </td>
                                                        </tr>
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </section>
