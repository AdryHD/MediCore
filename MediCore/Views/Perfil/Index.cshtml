@model MediCore.Models.PerfilModel
@using System.Linq
@{
    ViewBag.Title = "Configuración";
    ViewBag.ActiveMenu = "Perfil";
    var iniciales = string.IsNullOrWhiteSpace(Model.Nombre)
        ? "US"
        : string.Join("", Model.Nombre.Split(' ').Where(p => p.Length > 0).Take(2).Select(p => char.ToUpper(p[0])));
}

<div class="page-heading">
    <div>
        <span class="section-eyebrow">MI CUENTA</span>
        <h3>Configuración</h3>
    </div>
</div>

<section class="section">

    <div class="row mb-3">
        <div class="col-12">
            <div class="card">
                <div class="card-body d-flex align-items-center gap-3 flex-wrap">
                    <div class="navbar-avatar" style="width:64px;height:64px;font-size:1.4rem;">@iniciales</div>
                    <div>
                        <h4 class="mb-1">@Model.Nombre</h4>
                        <p class="mb-0 text-muted" style="font-size:0.9rem;">
                            <i class="bi bi-envelope me-1"></i>@Model.Correo
                            @if (!string.IsNullOrWhiteSpace(Model.NombreRol))
                            {
                                <span class="mx-2">&middot;</span>
                                <i class="bi bi-person-badge me-1"></i>@Model.NombreRol
                            }
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">

        <div class="col-12 col-lg-6">
            <div class="card">
                <div class="card-header">
                    <h4><i class="bi bi-shield-lock me-2" style="color:#01C0BA;"></i>Cambiar Contraseña</h4>
                </div>
                <div class="card-body">

                    @if (TempData["SuccessSeguridad"] != null)
                    {
                        <div class="alert alert-light-success" role="alert">@TempData["SuccessSeguridad"]</div>
                    }

                    @using (Html.BeginForm("CambiarContrasenna", "Perfil", FormMethod.Post, new { id = "CambiarContrasennaForm" }))
                    {
                        @Html.AntiForgeryToken()
                        if (!ViewData.ModelState.IsValid)
                        {
                            @Html.ValidationSummary(false, "", new { @class = "alert alert-light-danger" })
                        }

                        <div class="form-group mb-3">
                            @Html.Label("ContrasennaNueva", "Contraseña Nueva", new { @class = "form-label" })
                            @Html.Password("ContrasennaNueva", null, new { @class = "form-control", placeholder = "Mínimo 6 caracteres", maxlength = 10 })
                            @Html.ValidationMessage("ContrasennaNueva", "", new { @class = "text-danger small" })
                        </div>

                        <div class="form-group mb-3">
                            @Html.Label("ConfirmarContrasenna", "Confirmar Contraseña", new { @class = "form-label" })
                            @Html.Password("ConfirmarContrasenna", null, new { @class = "form-control", placeholder = "Confirmar contraseña", maxlength = 10 })
                            @Html.ValidationMessage("ConfirmarContrasenna", "", new { @class = "text-danger small" })
                        </div>

                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>Actualizar Contraseña
                        </button>
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="card">
                <div class="card-header">
                    <h4><i class="bi bi-person-lines-fill me-2" style="color:#01C0BA;"></i>Editar Perfil</h4>
                </div>
                <div class="card-body">

                    @if (TempData["SuccessPerfil"] != null)
                    {
                        <div class="alert alert-light-success" role="alert">@TempData["SuccessPerfil"]</div>
                    }

                    @using (Html.BeginForm("CambiarPerfil", "Perfil", FormMethod.Post, new { id = "CambiarPerfilForm" }))
                    {
                        @Html.AntiForgeryToken()
                        if (!ViewData.ModelState.IsValid)
                        {
                            @Html.ValidationSummary(false, "", new { @class = "alert alert-light-danger" })
                        }
                        @Html.HiddenFor(m => m.Consecutivo)

                        <div class="form-group mb-3">
                            @Html.LabelFor(m => m.Nombre)
                            @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control", maxlength = 250 })
                            @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger small" })
                        </div>

                        <div class="form-group mb-3">
                            @Html.LabelFor(m => m.Correo)
                            @Html.TextBoxFor(m => m.Correo, new { @class = "form-control", type = "email", maxlength = 100 })
                            @Html.ValidationMessageFor(m => m.Correo, "", new { @class = "text-danger small" })
                        </div>

                        <div class="form-group mb-3">
                            @Html.LabelFor(m => m.Telefono)
                            @Html.TextBoxFor(m => m.Telefono, new { @class = "form-control", maxlength = 20 })
                            @Html.ValidationMessageFor(m => m.Telefono, "", new { @class = "text-danger small" })
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label">Cédula</label>
                            <input type="text" class="form-control" value="@Model.Cedula" disabled readonly>
                        </div>

                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>Guardar Cambios
                        </button>
                    }
                </div>
            </div>
        </div>

    </div>
</section>
