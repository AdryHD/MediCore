@model IEnumerable<MediCore.EF.Doctores>
@{
    ViewBag.Title = "Doctores";
    ViewBag.ActiveMenu = "Doctores";

    var nombreEspecialidad = ViewBag.NombreEspecialidad as System.Collections.Generic.Dictionary<int, string>;
    int paginaActual = ViewBag.PaginaActual ?? 1;
    int totalPaginas = ViewBag.TotalPaginas ?? 0;
}

<div class="page-heading">
    <div>
        <span class="section-eyebrow">GESTIÓN MÉDICA</span>
        <h3>Doctores</h3>
    </div>
    <div>
        <a href="@Url.Action("Create", "Doctores")" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Nuevo Doctor
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-light-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-light-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<section class="section">
    <div class="card mb-3">
        <div class="card-body">
            @using (Html.BeginForm("Index", "Doctores", FormMethod.Get))
            {
                <div class="row g-2 align-items-end">
                    <div class="col-12 col-md-4">
                        <label class="form-label">Buscar</label>
                        <input type="text" name="q" value="@ViewBag.FiltroTexto" class="form-control" placeholder="Nombre, cédula o código colegiado" />
                    </div>
                    <div class="col-12 col-md-3">
                        <label class="form-label">Especialidad</label>
                        @Html.DropDownList("idEspecialidad", (SelectList)ViewBag.Especialidades, "Todas", new { @class = "form-select" })
                    </div>
                    <div class="col-12 col-md-3">
                        <label class="form-label">Estado</label>
                        <select name="estado" class="form-select">
                            <option value="">Todos</option>
                            <option value="ACTIVO"@(ViewBag.FiltroEstado == "ACTIVO" ? " selected" : "")>Activo</option>
                            <option value="INACTIVO"@(ViewBag.FiltroEstado == "INACTIVO" ? " selected" : "")>Inactivo</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-2 d-grid">
                        <button type="submit" class="btn btn-light-secondary">
                            <i class="bi bi-funnel me-1"></i>Filtrar
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h4><i class="bi bi-person-badge me-2" style="color:#01C0BA;"></i>Listado de Doctores</h4>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Nombre completo</th>
                            <th>Cédula</th>
                            <th>Código colegiado</th>
                            <th>Especialidad</th>
                            <th>Correo</th>
                            <th>Teléfono</th>
                            <th>Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.id_doctor</td>
                                    <td class="fw-semibold">@item.nombre_completo</td>
                                    <td>@item.cedula</td>
                                    <td>@item.codigo_colegiado</td>
                                    <td>@(nombreEspecialidad != null && nombreEspecialidad.ContainsKey(item.id_especialidad) ? nombreEspecialidad[item.id_especialidad] : "—")</td>
                                    <td>@item.correo</td>
                                    <td>@(string.IsNullOrWhiteSpace(item.telefono) ? "—" : item.telefono)</td>
                                    <td>
                                        @if (item.estado == "ACTIVO")
                                        {
                                            <span class="badge-status done"><i class="bi bi-check-circle"></i>Activo</span>
                                        }
                                        else
                                        {
                                            <span class="badge-status canceled"><i class="bi bi-slash-circle"></i>Inactivo</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a href="@Url.Action("Edit", "Doctores", new { id = item.id_doctor })" class="btn btn-light-secondary btn-sm" title="Editar">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        @if (item.estado == "ACTIVO")
                                        {
                                            using (Html.BeginForm("CambiarEstado", "Doctores", FormMethod.Post, new { id = "form-estado-" + item.id_doctor, style = "display:inline-block;" }))
                                            {
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.id_doctor" />
                                                <input type="hidden" name="nuevoEstado" value="INACTIVO" />
                                                <button type="button" class="btn btn-light-danger btn-sm btn-confirmar-estado" title="Desactivar"
                                                        data-form-id="form-estado-@item.id_doctor" data-nombre="@item.nombre_completo">
                                                    <i class="bi bi-toggle-off"></i>
                                                </button>
                                            }
                                        }
                                        else
                                        {
                                            using (Html.BeginForm("CambiarEstado", "Doctores", FormMethod.Post, new { style = "display:inline-block;" }))
                                            {
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.id_doctor" />
                                                <input type="hidden" name="nuevoEstado" value="ACTIVO" />
                                                <button type="submit" class="btn btn-light-success btn-sm" title="Activar">
                                                    <i class="bi bi-toggle-on"></i>
                                                </button>
                                            }
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="empty-state-cell">
                                    <div class="empty-state">
                                        <div class="empty-state-icon-wrap">
                                            <i class="bi bi-person-badge"></i>
                                        </div>
                                        <p class="empty-state-title">Sin doctores registrados</p>
                                        <p class="empty-state-sub">Aún no hay doctores que coincidan con los filtros aplicados.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        @if (totalPaginas > 1)
        {
            <div class="card-footer">
                <nav aria-label="Paginación de doctores">
                    <ul class="pagination justify-content-center mb-0">
                        <li class="page-item @(paginaActual <= 1 ? "disabled" : "")">
                            <a class="page-link" href="@Url.Action("Index", "Doctores", new { q = ViewBag.FiltroTexto, idEspecialidad = ViewBag.FiltroEspecialidad, estado = ViewBag.FiltroEstado, page = paginaActual - 1 })">Anterior</a>
                        </li>
                        @for (int i = 1; i <= totalPaginas; i++)
                        {
                            <li class="page-item @(i == paginaActual ? "active" : "")">
                                <a class="page-link" href="@Url.Action("Index", "Doctores", new { q = ViewBag.FiltroTexto, idEspecialidad = ViewBag.FiltroEspecialidad, estado = ViewBag.FiltroEstado, page = i })">@i</a>
                            </li>
                        }
                        <li class="page-item @(paginaActual >= totalPaginas ? "disabled" : "")">
                            <a class="page-link" href="@Url.Action("Index", "Doctores", new { q = ViewBag.FiltroTexto, idEspecialidad = ViewBag.FiltroEspecialidad, estado = ViewBag.FiltroEstado, page = paginaActual + 1 })">Siguiente</a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</section>

@* Modal de confirmación para desactivar un doctor *@
<div class="modal fade" id="mcConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content mc-modal">
            <div class="modal-body text-center">
                <div class="mc-modal-icon-wrap danger">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
                <h5 class="mc-modal-title">¿Desactivar doctor?</h5>
                <p class="mc-modal-text" id="mcConfirmText">Este doctor dejará de estar disponible para programar nuevas citas.</p>
            </div>
            <div class="modal-footer border-0 justify-content-center">
                <button type="button" class="btn btn-light-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-light-danger" id="mcConfirmBtn">Sí, desactivar</button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/Scripts/doctores.js?v=@System.IO.File.GetLastWriteTime(Server.MapPath("~/Scripts/doctores.js")).Ticks"></script>
}
