@model IEnumerable<MediCore.EF.Especialidades>
@{
    ViewBag.Title = "Especialidades";
    ViewBag.ActiveMenu = "Especialidades";
}

<div class="page-heading">
    <div>
        <span class="section-eyebrow">GESTIÓN MÉDICA</span>
        <h3>Especialidades</h3>
    </div>
    <div>
        <a href="@Url.Action("Create", "Especialidades")" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Nueva Especialidad
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-light-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-light-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<section class="section">
    <div class="card">
        <div class="card-header">
            <h4><i class="bi bi-award me-2" style="color:#01C0BA;"></i>Listado de Especialidades</h4>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Nombre</th>
                            <th>Descripción</th>
                            <th>Estado</th>
                            <th>Fecha Creación</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.id_especialidad</td>
                                    <td class="fw-semibold">@item.nombre</td>
                                    <td>@(string.IsNullOrWhiteSpace(item.descripcion) ? "—" : item.descripcion)</td>
                                    <td>
                                        @if (item.estado == "ACTIVO")
                                        {
                                            <span class="badge-status done"><i class="bi bi-check-circle"></i>Activo</span>
                                        }
                                        else
                                        {
                                            <span class="badge-status canceled"><i class="bi bi-slash-circle"></i>Inactivo</span>
                                        }
                                    </td>
                                    <td>@item.fecha_creacion.ToString("dd/MM/yyyy")</td>
                                    <td class="text-end">
                                        <a href="@Url.Action("Edit", "Especialidades", new { id = item.id_especialidad })" class="btn btn-light-secondary btn-sm" title="Editar">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        @if (item.estado == "ACTIVO")
                                        {
                                            using (Html.BeginForm("CambiarEstado", "Especialidades", FormMethod.Post, new { id = "form-estado-" + item.id_especialidad, style = "display:inline-block;" }))
                                            {
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.id_especialidad" />
                                                <input type="hidden" name="nuevoEstado" value="INACTIVO" />
                                                <button type="button" class="btn btn-light-danger btn-sm btn-confirmar-estado" title="Desactivar"
                                                        data-form-id="form-estado-@item.id_especialidad" data-nombre="@item.nombre">
                                                    <i class="bi bi-toggle-off"></i>
                                                </button>
                                            }
                                        }
                                        else
                                        {
                                            using (Html.BeginForm("CambiarEstado", "Especialidades", FormMethod.Post, new { style = "display:inline-block;" }))
                                            {
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.id_especialidad" />
                                                <input type="hidden" name="nuevoEstado" value="ACTIVO" />
                                                <button type="submit" class="btn btn-light-success btn-sm" title="Activar">
                                                    <i class="bi bi-toggle-on"></i>
                                                </button>
                                            }
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="empty-state-cell">
                                    <div class="empty-state">
                                        <div class="empty-state-icon-wrap">
                                            <i class="bi bi-award"></i>
                                        </div>
                                        <p class="empty-state-title">Sin especialidades registradas</p>
                                        <p class="empty-state-sub">Aún no hay especialidades médicas en el sistema.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

@* Modal de confirmación para desactivar una especialidad *@
<div class="modal fade" id="mcConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content mc-modal">
            <div class="modal-body text-center">
                <div class="mc-modal-icon-wrap danger">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
                <h5 class="mc-modal-title">¿Desactivar especialidad?</h5>
                <p class="mc-modal-text" id="mcConfirmText">Esta especialidad dejará de estar disponible para programar nuevas citas.</p>
            </div>
            <div class="modal-footer border-0 justify-content-center">
                <button type="button" class="btn btn-light-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-light-danger" id="mcConfirmBtn">Sí, desactivar</button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/Scripts/especialidades.js?v=@System.IO.File.GetLastWriteTime(Server.MapPath("~/Scripts/especialidades.js")).Ticks"></script>
}
